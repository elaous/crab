# PostgreSQL connection string
DATABASE_URL="postgresql://crab:crab@localhost:5432/crabcad"

# Port the API listens on (default: 3001)
PORT=3001

# Allowed CORS origin — set to your frontend URL in production
CORS_ORIGIN="http://localhost:8080"

# Set to "false" to disable token auth (useful for local dev / single-user)
CRABCAD_AUTH=false

# Node environment
NODE_ENV=development
