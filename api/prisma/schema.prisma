generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Scene {
  id        String   @id @default(cuid())
  name      String
  data      Bytes
  ownerId   String?
  shares    Share[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, updatedAt(sort: Desc)])
}

model Share {
  id         String    @id @default(cuid())
  scene      Scene     @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  sceneId    String
  token      String    @unique @default(cuid())
  permission String    @default("viewer") // "viewer" | "editor" | "owner"
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([sceneId])
}

model Plugin {
  id        String   @id @default(cuid())
  name      String
  version   String
  code      String   @db.Text
  manifest  Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiToken {
  id        String    @id @default(cuid())
  token     String    @unique
  label     String
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}
